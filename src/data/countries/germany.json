{
  "country": "Germany",
  "language": "German/English",
  "style": "structured_professional",
  "tips": [
    "Use clear chronology and factual bullets.",
    "Keep section separators strong and readable.",
    "Show role scope and operational responsibilities."
  ],
  "focus_keywords": ["operations", "management", "responsibility", "efficiency"],
  "format": {
    "template_name": "germany_classic_black_rules",
    "layout_mode": "vertical_single_column",
    "page": {
      "size": "A4",
      "margins_mm": 14,
      "background": "#f2f2f2"
    },
    "header": {
      "name_alignment": "center",
      "name_case": "title",
      "title_under_name": true,
      "contact_inline": true,
      "top_band": {
        "enabled": false,
        "height_mm": 0,
        "color": "#000000"
      }
    },
    "section_style": {
      "title_case": "title",
      "divider": "thick_black_line",
      "divider_color": "#111111",
      "spacing_after_title_mm": 2
    },
    "content": {
      "section_order": [
        "Summary",
        "Work Experience",
        "Education",
        "Skills"
      ],
      "bullet_style": "dot",
      "date_style": "YYYY-MM",
      "date_alignment": "right_on_role_line",
      "skills_layout": "two_columns",
      "max_pages": 2,
      "include_photo": false
    },
    "ats": {
      "allow_tables": false,
      "allow_icons": false,
      "section_titles_plain_text": true
    }
  }
}
