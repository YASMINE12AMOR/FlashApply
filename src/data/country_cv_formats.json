{
  "cv_customizer_agent": {
    "version": "1.0.0",
    "description": "CV Customizer Agent configuration containing country-specific CV rules, formatting, and content guidelines.",
    "countries": {
      "USA": {
        "meta": {
          "document_name": "Résumé",
          "language": "American English",
          "flag": "🇺🇸"
        },
        "format": {
          "length": {
            "min_pages": 1,
            "max_pages": 2,
            "rule": "1 page for entry-level, 2 pages max for experienced professionals. Academic CV is separate and can be 5–15+ pages."
          },
          "layout": "reverse_chronological",
          "font_recommended": ["Calibri", "Garamond", "Arial"],
          "font_size_body": "10–12pt",
          "margins": "0.5–1 inch",
          "file_format": ["PDF", "DOCX"],
          "ats_optimized": true
        },
        "personal_information": {
          "name": { "required": true },
          "email": { "required": true },
          "phone": { "required": true },
          "linkedin": { "required": false, "recommended": true },
          "city_state": { "required": false, "recommended": true },
          "photo": { "required": false, "allowed": false, "reason": "Anti-discrimination laws" },
          "date_of_birth": { "required": false, "allowed": false, "reason": "Anti-discrimination laws" },
          "nationality": { "required": false, "allowed": false, "reason": "Anti-discrimination laws" },
          "marital_status": { "required": false, "allowed": false, "reason": "Anti-discrimination laws" },
          "gender": { "required": false, "allowed": false },
          "religion": { "required": false, "allowed": false }
        },
        "sections": {
          "order": [
            "summary_or_objective",
            "work_experience",
            "education",
            "skills",
            "certifications",
            "volunteer_work",
            "awards"
          ],
          "summary_or_objective": {
            "required": false,
            "recommended": true,
            "description": "3–5 lines personal branding statement. Use 'Summary' for experienced, 'Objective' for entry-level."
          },
          "work_experience": {
            "required": true,
            "format": "reverse_chronological",
            "bullet_points": true,
            "quantify_achievements": true,
            "action_verbs": true,
            "description": "Use strong action verbs and quantify results (e.g., 'Increased revenue by 30%')."
          },
          "education": {
            "required": true,
            "include_gpa": { "rule": "Only if 3.5+ or recent graduate" },
            "include_high_school": false
          },
          "skills": {
            "required": true,
            "types": ["technical", "software", "languages"]
          },
          "references": {
            "required": false,
            "allowed": false,
            "note": "Write 'Available upon request' only if space allows, or omit entirely."
          },
          "hobbies_interests": {
            "required": false,
            "recommended": false,
            "note": "Generally not included unless directly relevant to the job."
          },
          "volunteer_work": {
            "required": false,
            "recommended": false
          }
        },
        "cover_letter": {
          "required": false,
          "recommended": true,
          "weight": "medium"
        },
        "tone": {
          "style": "achievement-oriented",
          "voice": "third-person implied (no 'I')",
          "keywords": "ATS-friendly keywords essential"
        },
        "cultural_notes": [
          "CV is treated as a personal brand marketing document.",
          "Quantified accomplishments are expected.",
          "ATS screening is very common — tailor keywords per job posting.",
          "Avoid any personal data that could trigger discrimination."
        ]
      },

      "UK": {
        "meta": {
          "document_name": "CV",
          "language": "British English",
          "flag": "🇬🇧"
        },
        "format": {
          "length": {
            "min_pages": 2,
            "max_pages": 2,
            "rule": "2 pages is the strong standard. 1 page acceptable for entry-level."
          },
          "layout": "reverse_chronological",
          "font_recommended": ["Calibri", "Arial", "Times New Roman"],
          "font_size_body": "10–12pt",
          "margins": "1.5–2 cm",
          "file_format": ["PDF", "DOCX"],
          "ats_optimized": true
        },
        "personal_information": {
          "name": { "required": true },
          "email": { "required": true },
          "phone": { "required": true },
          "linkedin": { "required": false, "recommended": true },
          "city": { "required": false, "recommended": true },
          "photo": { "required": false, "allowed": false, "reason": "Equality Act 2010 discourages it" },
          "date_of_birth": { "required": false, "allowed": false, "reason": "Discrimination concerns" },
          "nationality": { "required": false, "allowed": false },
          "marital_status": { "required": false, "allowed": false },
          "gender": { "required": false, "allowed": false }
        },
        "sections": {
          "order": [
            "personal_statement",
            "work_experience",
            "education",
            "skills",
            "hobbies_interests",
            "references"
          ],
          "personal_statement": {
            "required": true,
            "length": "4–6 sentences",
            "description": "Career summary placed at the top. Explains who you are, what you've done, and what you're looking for."
          },
          "work_experience": {
            "required": true,
            "format": "reverse_chronological",
            "bullet_points": true,
            "quantify_achievements": true,
            "action_verbs": true
          },
          "education": {
            "required": true,
            "include_high_school": true,
            "include_gpa": { "rule": "Include degree classification (1st, 2:1, 2:2, etc.)" }
          },
          "skills": {
            "required": true,
            "types": ["technical", "soft", "languages"]
          },
          "hobbies_interests": {
            "required": false,
            "recommended": true,
            "note": "Still fairly common in UK CVs. Shows personality and cultural fit."
          },
          "references": {
            "required": false,
            "note": "Write 'References available upon request'. Listing references directly is becoming less common."
          }
        },
        "cover_letter": {
          "required": false,
          "recommended": true,
          "weight": "medium-high"
        },
        "tone": {
          "style": "professional and structured",
          "voice": "third-person implied",
          "keywords": "Tailor for each application"
        },
        "cultural_notes": [
          "Always use British English spelling (organisation, analyse, centre).",
          "Hobbies and interests are still valued for personality insight.",
          "The personal statement is a key differentiator — invest time in it.",
          "Degree classification (First, 2:1, etc.) is important to mention."
        ]
      },

      "Germany": {
        "meta": {
          "document_name": "Lebenslauf",
          "language": "German (or English for international companies)",
          "flag": "🇩🇪"
        },
        "format": {
          "length": {
            "min_pages": 2,
            "max_pages": 3,
            "rule": "2–3 pages. Thoroughness is valued. Attach full document set (Bewerbungsmappe)."
          },
          "layout": "reverse_chronological",
          "font_recommended": ["Calibri", "Arial", "Times New Roman"],
          "font_size_body": "11–12pt",
          "margins": "2 cm",
          "file_format": ["PDF"],
          "ats_optimized": false,
          "application_package": {
            "name": "Bewerbungsmappe",
            "components": ["cover_letter", "cv", "certificates", "diplomas", "reference_letters"]
          }
        },
        "personal_information": {
          "name": { "required": true },
          "email": { "required": true },
          "phone": { "required": true },
          "address": { "required": true },
          "date_of_birth": { "required": true },
          "place_of_birth": { "required": true },
          "nationality": { "required": true },
          "marital_status": { "required": true },
          "photo": {
            "required": true,
            "style": "professional passport-style headshot",
            "position": "top right corner",
            "size": "3.5 x 4.5 cm"
          }
        },
        "sections": {
          "order": [
            "personal_information_with_photo",
            "education",
            "work_experience",
            "internships",
            "language_skills",
            "computer_skills",
            "certifications",
            "volunteer_work",
            "hobbies_interests",
            "signature_and_date"
          ],
          "education": {
            "required": true,
            "listed_before_experience": true,
            "include_grades": true,
            "note": "Include GPA/grade for each qualification — German employers scrutinize academic performance."
          },
          "work_experience": {
            "required": true,
            "format": "reverse_chronological",
            "bullet_points": true,
            "quantify_achievements": true
          },
          "language_skills": {
            "required": true,
            "use_cefr_scale": true,
            "description": "Use CEFR levels (A1–C2) for each language."
          },
          "signature_and_date": {
            "required": true,
            "note": "Sign and date the CV at the bottom — this is a formal German business tradition."
          },
          "hobbies_interests": {
            "required": false,
            "recommended": true
          },
          "references": {
            "required": false,
            "note": "Arbeitszeugnisse (employer reference letters) are submitted as attachments, not listed in the CV."
          }
        },
        "cover_letter": {
          "required": true,
          "name": "Anschreiben",
          "weight": "very high",
          "note": "Mandatory. Formal, precise, and structured. Must be tailored to the specific role."
        },
        "tone": {
          "style": "formal, precise, and detailed",
          "voice": "first-person (in cover letter), factual in CV",
          "keywords": "Industry-specific terminology expected"
        },
        "cultural_notes": [
          "Germany places high importance on formal qualifications and certificates.",
          "A professional photo is mandatory and expected.",
          "Arbeitszeugnisse (work reference certificates from past employers) must be included.",
          "Thoroughness and detail are virtues — do not omit information.",
          "Education section typically comes before work experience.",
          "Sign and date the CV — it signals formal commitment."
        ]
      },

      "France": {
        "meta": {
          "document_name": "CV (Curriculum Vitae)",
          "language": "French (or English for international companies)",
          "flag": "🇫🇷"
        },
        "format": {
