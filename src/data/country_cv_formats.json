          "date_of_birth": { "required": false, "commonly_included": true },
          "nationality": { "required": false, "commonly_included": true },
          "marital_status": { "required": false, "commonly_included": false },
          "photo": {
            "required": false,
            "commonly_included": true,
            "style": "professional headshot",
            "position": "top right or top left"
          }
        },
        "sections": {
          "order": [
            "personal_information_with_photo",
            "professional_summary",
            "work_experience",
            "education",
            "skills",
            "languages",
            "hobbies_interests"
          ],
