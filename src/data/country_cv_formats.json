          },
          "layout": "reverse_chronological",
          "font_recommended": ["Garamond", "Gill Sans", "Calibri"],
          "font_size_body": "10–11pt",
          "margins": "1.5–2 cm",
          "file_format": ["PDF"],
          "visual_design": "important",
          "ats_optimized": false
        },
        "personal_information": {
