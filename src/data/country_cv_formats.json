            "required": false,
            "recommended": true,
            "length": "2–4 lines"
          },
          "work_experience": {
            "required": true,
            "format": "reverse_chronological",
            "bullet_points": true,
            "quantify_achievements": true
          },
          "education": {
            "required": true,
            "include_grandes_ecoles": true,
            "note": "Grandes Écoles (HEC, Sciences Po, Polytechnique, etc.) carry immense prestige. Always highlight."
          },
          "languages": {
            "required": true,
            "use_cefr_scale": true
          },
          "hobbies_interests": {
            "required": false,
            "recommended": true,
            "note": "French employers appreciate personal interests as a reflection of personality and cultural depth."
          },
          "references": {
            "required": false,
            "note": "Not typically listed in the CV."
          }
        },
        "cover_letter": {
          "required": true,
          "name": "Lettre de motivation",
          "weight": "very high",
          "note": "Eloquence and writing style matter enormously. Must demonstrate motivation and personality."
        },
        "tone": {
          "style": "elegant, concise, and personal",
          "voice": "first-person (in cover letter)",
          "keywords": "Aesthetic presentation valued"
        },
        "cultural_notes": [
          "Conciseness is a sign of intelligence — aim for 1 page.",
          "Visual design and elegance matter; a well-formatted CV stands out.",
          "Grandes Écoles credentials are very prestigious — highlight them prominently.",
          "The Lettre de motivation is as important as the CV itself — invest heavily in it.",
          "Hobbies and interests reflect cultural fit and are genuinely considered.",
          "French employers may still expect a photo, though it is not legally required."
        ]
      },

