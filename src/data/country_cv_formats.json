      }
    },

    "agent_rules": {
      "detection": "Detect target country from user input and load corresponding country profile.",
      "customization_steps": [
        "1. Ask user for target country.",
        "2. Apply country-specific length, layout, and format rules.",
        "3. Include or exclude personal information fields based on country rules.",
        "4. Reorder sections according to country's expected section order.",
        "5. Apply correct photo rule (include/exclude).",
        "6. Adjust tone and language (British vs American English, formal vs marketing-style).",
        "7. Flag missing mandatory sections (e.g., Anschreiben for Germany, Lettre de motivation for France).",
        "8. Provide cultural tips relevant to the target country."
      ],
      "output_format": "Tailored CV in PDF or DOCX based on user preference.",
      "validation_checks": [
        "Page count within allowed range",
        "No prohibited personal info included",
        "Mandatory sections present",
        "Photo included/excluded correctly",
        "Cover letter flagged if mandatory",
        "Language matches target country standard"
      ]
    }
