{
  "cv_customizer_agent": {
    "version": "3.0.0",
    "description": "Country-specific CV format profiles derived from provided samples (France, Germany, Canada only), optimized for PDF generation.",
    "countries": {
      "France": {
        "source_confidence": "from_user_sample",
        "meta": {
          "document_name": "CV",
          "language": "French or English",
          "flag": "FR"
        },
        "format": {
          "length": {
            "min_pages": 1,
            "max_pages": 2,
            "rule": "1 page preferred, 2 pages max for senior profiles."
          },
          "layout": "two_column",
          "file_format": ["PDF"],
          "ats_optimized": false
        },
        "design_pattern": {
          "overall_structure": "left_sidebar + right_main",
          "header_style": "photo_left_name_title_top",
          "section_title_style": "uppercase_bold_with_separator",
          "body_density": "high",
          "bullet_style": "solid_round",
          "date_alignment": "left_inline",
          "visual_priority": "high"
        },
        "sidebar_layout": {
          "enabled": true,
          "width_ratio": "33:67",
          "position": "left",
          "blocks_order": [
            "contact",
            "details",
            "core_competencies",
            "technical_summary"
          ]
        },
        "personal_information": {
          "name": { "required": true },
          "email": { "required": true },
          "phone": { "required": true },
          "address": { "recommended": true },
          "photo": { "allowed": true, "recommended": true },
          "date_of_birth": { "allowed": true, "recommended": true },
          "nationality": { "allowed": true, "recommended": true },
          "marital_status": { "allowed": true, "recommended": false }
        },
        "sections": {
          "order": [
            "header_with_photo",
            "summary",
            "work_experience",
            "education"
          ],
          "sidebar_sections": [
            "contact",
            "details",
            "core_competencies",
            "technical_summary"
          ],
          "summary": { "required": true, "length": "3-6 lines" },
          "work_experience": {
            "required": true,
            "bullet_points": true,
            "accomplishments_subsection": true,
            "reverse_chronological": true
          },
          "education": { "required": true }
        },
        "tone": {
          "style": "professional, technical, concise",
          "voice": "factual and clear"
        }
      },
      "Germany": {
        "source_confidence": "from_user_sample",
        "meta": {
          "document_name": "Lebenslauf",
          "language": "German or English",
          "flag": "DE"
        },
        "format": {
          "length": {
            "min_pages": 1,
            "max_pages": 2,
            "rule": "1-2 pages in this sample style, dense and technical."
          },
          "layout": "single_column",
          "file_format": ["PDF"],
          "ats_optimized": true
        },
        "design_pattern": {
          "overall_structure": "single_column_dense",
          "header_style": "centered_name + contact_line",
          "section_title_style": "uppercase_bold + horizontal_rule",
          "body_density": "very_high",
          "bullet_style": "solid_round",
          "date_alignment": "right",
          "location_alignment": "right",
          "keyword_emphasis": "bold_inline_metrics"
        },
        "personal_information": {
          "name": { "required": true },
          "email": { "required": true },
          "phone": { "required": true },
          "linkedin": { "recommended": true },
          "location": { "recommended": true },
          "photo": { "allowed": false, "recommended": false }
        },
        "sections": {
          "order": [
            "header",
            "work_experience",
            "projects",
            "skills",
            "languages",
            "education"
          ],
          "work_experience": {
            "required": true,
            "bullet_points": true,
            "reverse_chronological": true,
            "date_right_aligned": true,
            "location_right_aligned": true
          },
          "projects": {
            "required": true,
            "bullet_points": true,
            "show_keywords_line": true
          },
          "skills": {
            "required": true,
            "grouped_by_category": true
          },
          "languages": { "required": true },
          "education": { "required": true, "reverse_chronological": true }
        },
        "tone": {
          "style": "technical, results-driven, precise",
          "voice": "compact and measurable"
        }
      },
      "Canada": {
        "source_confidence": "from_user_sample",
        "meta": {
          "document_name": "Resume",
          "language": "French (sample) / English",
          "flag": "CA"
        },
        "format": {
          "length": {
            "min_pages": 1,
            "max_pages": 2,
            "rule": "1 page preferred, 2 pages max."
          },
          "layout": "single_column",
          "file_format": ["PDF"],
          "ats_optimized": true
        },
        "design_pattern": {
          "overall_structure": "header_split + single_main_column",
          "header_style": "name_title_left_contact_right",
          "section_title_style": "uppercase_bold + heavy_horizontal_rule",
          "body_density": "medium_high",
          "bullet_style": "solid_round",
          "date_alignment": "left_inline_for_period",
          "role_emphasis": "bold_role_title"
        },
        "header_layout": {
          "type": "two_zone",
          "left_zone": ["full_name", "job_title"],
          "right_zone": ["phone", "email", "location", "linkedin"]
        },
        "personal_information": {
          "name": { "required": true },
          "email": { "required": true },
          "phone": { "required": true },
          "city_province": { "recommended": true },
          "linkedin": { "recommended": true },
          "photo": { "allowed": false },
          "date_of_birth": { "allowed": false },
          "nationality": { "allowed": false },
          "marital_status": { "allowed": false }
        },
        "sections": {
          "order": [
            "header",
            "objectif",
            "competences",
            "langues",
            "experience_professionnelle",
            "education_optional"
          ],
          "objectif": { "required": true, "length": "3-6 lines" },
          "competences": {
            "required": true,
            "layout": "two_columns_bullets"
          },
          "langues": {
            "required": true,
            "display_mode": "label + visual_level_bar"
          },
          "experience_professionnelle": {
            "required": true,
            "bullet_points": true,
            "date_and_location_before_role": true
          }
        },
        "tone": {
          "style": "professional, managerial, communication-focused",
          "voice": "clear and practical"
        }
      }
    }
  }
}
